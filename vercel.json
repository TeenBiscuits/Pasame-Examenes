{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/en/(.*)", "destination": "/index.html" },
    { "source": "/es/(.*)", "destination": "/index.html" },
    { "source": "/gl/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
