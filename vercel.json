{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
        "source": "/:lang(en|es|gl)",
        "destination": "/og-pages/:lang/home.html"
    },
    {
        "source": "/:lang(en|es|gl)/:subjectId(_template|bede|cepe|deese|ece|emeele|equisi|equispe|esei|eseo|iesede|peese|pei|redes)",
        "destination": "/og-pages/:lang/:subjectId.html"
    },
    {
        "source": "/:lang(en|es|gl)/:subjectId(_template|bede|cepe|deese|ece|emeele|equisi|equispe|esei|eseo|iesede|peese|pei|redes)/practice/:topic*",
        "destination": "/og-pages/:lang/:subjectId.html"
    },
    {
        "source": "/:lang(en|es|gl)/:subjectId(_template|bede|cepe|deese|ece|emeele|equisi|equispe|esei|eseo|iesede|peese|pei|redes)/exam/:year",
        "destination": "/og-pages/:lang/:subjectId.html"
    },
    {
        "source": "/en/(.*)",
        "destination": "/index.html"
    },
    {
        "source": "/es/(.*)",
        "destination": "/index.html"
    },
    {
        "source": "/gl/(.*)",
        "destination": "/index.html"
    },
    {
        "source": "/(.*)",
        "destination": "/index.html"
    }
],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/exams/(.*).pdf",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(favicon|og|apple-touch-icon|favicon-96x96|web-app-manifest)(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
